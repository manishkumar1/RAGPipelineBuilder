# ── Required ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Session security (change this to a random string in production) ────────
SECRET_KEY=change-me-to-a-random-secret

# ── Google OAuth2 (https://console.cloud.google.com/apis/credentials) ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Microsoft Azure AD (https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps) ──
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
